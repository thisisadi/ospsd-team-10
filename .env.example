# Base URL of Team 9's chat client service (no trailing slash). Example: https://os-bmaq.onrender.com
CHAT_SERVICE_BASE_URL=

# Session id from Team 9 after Slack OAuth: POST /auth/sessions, complete OAuth, then set this.
# Sessions are in-memory; they are lost when Team 9 restarts the server — refresh OAuth and update this.
CHAT_SESSION_ID=

# OpenAI API key used by the HW3 /agent route.
OPENAI_API_KEY=

# Optional OpenAI model override for the HW3 /agent route. Example: gpt-4o-mini
OPENAI_MODEL=

# Agent endpoint shared secret. Callers to POST /agent must send header X-API-Key with this value.
AGENT_API_KEY=
